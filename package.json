{
  "name": "kuzushi-security-plugin",
  "version": "0.9.0",
  "description": "Local-first vulnerability confirmation and remediation pipeline for Claude Code: threat modeling, SAST/taint, PoC/fuzz proof, rule synthesis, SARIF, and PoC+ patch validation.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "bench": "node bench/run.mjs",
    "bench:cve": "node bench/run.mjs --cve",
    "bench:smoke": "node scripts/cmd/bench-smoke.mjs",
    "eval": "node eval/eval.mjs",
    "eval:cve": "node eval/eval.mjs --cve",
    "eval:deep-hunt": "node eval/eval.mjs --mode deep-hunt",
    "eval:deep-hunt:cve": "node eval/eval.mjs --mode deep-hunt --cve",
    "eval:discover": "node eval/eval.mjs --mode discover",
    "eval:discover:cve": "node eval/eval.mjs --mode discover --cve"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "0.9.5",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pyright": "^1.1.400",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.6.0",
    "typescript-language-server": "^4.3.3",
    "web-tree-sitter": "^0.24.4",
    "zod": "^3.23.0"
  }
}
