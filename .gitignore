# Dependencies (restored with `npm install`; package-lock.json IS committed)
node_modules/

# Vendored analysis tools downloaded on demand (large, platform-specific) — see /install
vendor/

# Per-target analysis artifacts the plugin writes into a repo it scans
.kuzushi/
x-ray/

# Joern scratch: `joern`/`joern-parse` unpack a CPG into ./workspace when run
# from the repo root (default project dir) — regenerable, never source.
workspace/

# Real-CVE benchmark sources are cloned on demand by bench/cves/<id>/fetch.sh —
# third-party code, never committed. The fetch script + expected.json ARE committed.
bench/cves/*/repo/
bench/scoreboard.cve.md
# eval scoreboards are run-specific (model/cost/timestamp); the curated record is eval/README.md
eval/scoreboard.md
eval/scoreboard.cve.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets (never commit these)
.env
.env.*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude Code runtime state
.claude/
