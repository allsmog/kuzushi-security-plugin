{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kuzushi.local/schemas/poc.v1.schema.json",
  "title": "Kuzushi poc.v1",
  "type": "object",
  "required": ["proofLevel", "proofVerdict", "backend", "provenAt"],
  "properties": {
    "schemaVersion": { "const": "poc.v1" },
    "proofLevel": { "type": "integer", "minimum": 1, "maximum": 5 },
    "proofVerdict": {
      "type": "string",
      "enum": ["exploited", "not-reproduced", "non-discriminating", "harness-failed-build", "timeout", "error"]
    },
    "differential": {
      "type": "string",
      "enum": ["discriminated", "benign-also-fired", "benign-inconclusive", "attack-did-not-fire", "not-tested"]
    },
    "reproductions": {
      "type": "object",
      "description": "Reproducibility of the attack across N runs (the 3/3 standard). proofLevel 5 requires rate 1.",
      "properties": {
        "fired": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "backend": { "type": "string" },
    "durationMs": { "type": ["number", "null"] },
    "harnessDir": { "type": "string" },
    "runCommand": { "type": "string" },
    "logPath": { "type": "string" },
    "provenAt": { "type": "string" }
  }
}
