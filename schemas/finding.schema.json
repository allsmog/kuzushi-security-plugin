{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kuzushi.local/schemas/finding.v1.schema.json",
  "title": "Kuzushi finding.v1",
  "type": "object",
  "required": ["fingerprint", "source", "refId", "title", "severity", "status", "proofState", "evidence"],
  "properties": {
    "schemaVersion": { "const": "finding.v1" },
    "fingerprint": { "type": "string", "minLength": 8 },
    "source": { "type": "string", "minLength": 1 },
    "refId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "severity": { "type": "string" },
    "cwe": {},
    "verdict": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["lead", "candidate", "open", "needs-evidence", "needs-trace", "confirmed", "proven", "patched", "remediated", "reviewed", "noise"]
    },
    "proofState": {
      "type": "string",
      "enum": ["lead", "candidate", "open", "reachable", "trigger-built", "confirmed", "proven", "patch-planned", "patch-validated", "remediated", "reviewed", "noise"]
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceAnchor" }
    },
    "evidenceGraph": {
      "type": "object",
      "properties": {
        "nodes": { "type": "array" },
        "edges": { "type": "array" }
      }
    },
    "verification": { "$ref": "verification.schema.json" },
    "poc": { "$ref": "poc.schema.json" },
    "fuzz": { "type": "object" },
    "fix": { "$ref": "fix.schema.json" },
    "rationale": { "type": "string" },
    "nextChecks": { "type": "array" },
    "preconditions": {
      "type": "array",
      "description": "Conditions that must hold for exploitation. Count + accessLevel feed the deterministic severity derivation (scripts/lib/severity.mjs).",
      "items": { "type": "string" }
    },
    "accessLevel": {
      "type": "string",
      "description": "Minimum access the attacker needs (e.g. unauthenticated-remote / authenticated / local-only). Severity column; see severity.mjs."
    },
    "severityBasis": {
      "type": "object",
      "description": "How the stored severity was derived (precondition count, access level, threat-model boost) plus the advisory claimed-vs-derived inflation judgment."
    },
    "exclusionRule": {
      "description": "When a producer drops a candidate as a non-finding, the numbered false-positive rule (1-16) it matched. Tallies why things were excluded.",
      "type": ["integer", "string", "null"]
    },
    "refuteReason": {
      "type": "string",
      "description": "Why a candidate was refuted: doesnt_exist | already_handled | implausible_trigger | intentional_behavior | misread_code | duplicate | not_actionable | n/a."
    },
    "updatedAt": { "type": "string" }
  },
  "$defs": {
    "evidenceAnchor": {
      "type": "object",
      "required": ["filePath"],
      "properties": {
        "filePath": { "type": "string", "minLength": 1 },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
