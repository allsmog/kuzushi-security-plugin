{
  "version": 1,
  "mode": "defensive",
  "activeProfile": "developer-fast",
  "profiles": {
    "developer-fast": {
      "mcp": {
        "rawQuery": "allow"
      },
      "git": {
        "apply": "require-approval"
      },
      "guardrails": {
        "onHookError": "allow"
      },
      "analysis": {
        "autoBuildDatabases": "when-installed",
        "primaryBackend": "joern"
      },
      "install": {
        "autoInstallLightTools": true,
        "allowNetworkInstall": "approval-only",
        "requirePinnedDigests": false
      }
    },
    "review-safe": {
      "mcp": {
        "rawQuery": "require-approval"
      },
      "git": {
        "apply": "require-approval"
      },
      "guardrails": {
        "onHookError": "require-approval"
      },
      "analysis": {
        "autoBuildDatabases": "when-installed",
        "primaryBackend": "joern"
      },
      "install": {
        "autoInstallLightTools": false,
        "allowNetworkInstall": "approval-only",
        "requirePinnedDigests": false
      }
    },
    "ci-locked": {
      "mcp": {
        "rawQuery": "deny"
      },
      "git": {
        "apply": "deny"
      },
      "network": {
        "default": "deny",
        "allow": []
      },
      "guardrails": {
        "onHookError": "deny"
      },
      "analysis": {
        "autoBuildDatabases": "off",
        "primaryBackend": "joern"
      },
      "install": {
        "autoInstallLightTools": false,
        "allowNetworkInstall": "deny",
        "requirePinnedDigests": true
      }
    }
  },
  "filesystem": {
    "writeRoots": [
      ".kuzushi"
    ],
    "denyGlobs": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.ssh/**",
      "**/.aws/**",
      "**/.gnupg/**",
      "**/.kube/**",
      "**/.npmrc",
      "**/.pypirc"
    ]
  },
  "network": {
    "default": "deny",
    "allow": [
      "api.osv.dev",
      "services.nvd.nist.gov",
      "api.github.com"
    ]
  },
  "exec": {
    "subprocessAllowlist": [
      "semgrep",
      "codeql",
      "joern",
      "joern-parse",
      "git",
      "cc",
      "clang",
      "clang++",
      "gcc",
      "g++",
      "node",
      "python3",
      "rustc",
      "cargo",
      "go",
      "javac"
    ]
  },
  "mcp": {
    "rawQuery": "allow",
    "confineQueryPaths": true,
    "maxQueryBytes": 200000
  },
  "git": {
    "apply": "require-approval"
  },
  "guardrails": {
    "onHookError": "allow"
  },
  "install": {
    "autoInstallLightTools": true,
    "allowNetworkInstall": "approval-only",
    "requirePinnedDigests": false
  }
}
